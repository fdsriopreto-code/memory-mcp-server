generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "windows", "darwin", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  memories      Memory[]
  connections   ProjectConnection[]
  tasks         Task[]
  auditLogs     AuditLog[]
  writeRequests WriteRequest[]
  accessLogs    MemoryAccessLog[]
  anchors       MemoryAnchor[]
  digests       BrainDigest[]

  @@map("projects")
}

model Memory {
  id              String          @id @default(cuid())
  projectId       String          @map("project_id")
  type            MemoryType
  title           String
  content         String
  tags            String[]
  importance      Int             @default(3)
  isPinned        Boolean         @default(false) @map("is_pinned")
  embedding       Unsupported("vector(1536)")?
  accessCount     Int             @default(0) @map("access_count")
  accessedAt      DateTime?       @map("accessed_at")
  epistemicStatus EpistemicStatus @default(HYPOTHESIS) @map("epistemic_status")
  driftScore      Float           @default(0.0)        @map("drift_score")
  authorName      String?                              @map("author_name")
  authorEmail     String?                              @map("author_email")
  validatedCount  Int             @default(0)          @map("validated_count")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  links      MemoryLink[]    @relation("LinkFrom")
  linkedBy   MemoryLink[]    @relation("LinkTo")
  accessLogs MemoryAccessLog[]
  versions   MemoryVersion[]

  @@map("memories")
}

enum MemoryType {
  DECISION
  CONTEXT
  PATTERN
  NOTE
  BUG_FIX
  ARCHITECTURE
  BRAIN
  SYNTHESIS

  @@map("memory_type")
}

enum EpistemicStatus {
  HYPOTHESIS
  VALIDATED
  CONTESTED
  DEPRECATED

  @@map("epistemic_status")
}

model MemoryLink {
  id         String   @id @default(cuid())
  fromId     String   @map("from_id")
  toId       String   @map("to_id")
  relation   LinkType
  weight     Float    @default(1.0)
  confidence Float    @default(1.0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  from Memory @relation("LinkFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   Memory @relation("LinkTo",   fields: [toId],   references: [id], onDelete: Cascade)

  @@unique([fromId, toId, relation])
  @@map("memory_links")
}

enum LinkType {
  EXTENDS
  SUPERSEDES
  CONTRADICTS
  DEPENDS_ON
  EXAMPLE_OF
  RELATED
  CAUSES

  @@map("link_type")
}

model MemoryAccessLog {
  id         String   @id @default(cuid())
  memoryId   String   @map("memory_id")
  projectId  String   @map("project_id")
  dayOfWeek  Int      @map("day_of_week")
  hourOfDay  Int      @map("hour_of_day")
  accessedAt DateTime @default(now()) @map("accessed_at")

  memory  Memory  @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("memory_access_logs")
}

model ProjectConnection {
  id               String         @id @default(cuid())
  projectId        String         @map("project_id")
  type             ConnectionType
  name             String
  connectionString String         @map("connection_string")
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  writeRequests WriteRequest[]

  @@map("project_connections")
}

enum ConnectionType {
  POSTGRES
  REDIS

  @@map("connection_type")
}

model WriteRequest {
  id            String             @id @default(cuid())
  projectId     String             @map("project_id")
  connectionId  String             @map("connection_id")
  sql           String
  reason        String
  circumstances String
  status        WriteRequestStatus @default(PENDING)
  result        String?
  requestedAt   DateTime           @default(now()) @map("requested_at")
  resolvedAt    DateTime?          @map("resolved_at")

  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  connection ProjectConnection @relation(fields: [connectionId], references: [id])

  @@map("write_requests")
}

enum WriteRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED

  @@map("write_request_status")
}

model Task {
  id          String       @id @default(cuid())
  projectId   String       @map("project_id")
  title       String
  description String?
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(MEDIUM)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED

  @@map("task_status")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("task_priority")
}

model ExternalService {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String   @map("display_name")
  apiUrl        String   @map("api_url")
  adminEmail    String   @map("admin_email")
  adminPassword String   @map("admin_password")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("external_services")
}

model MemoryVersion {
  id           String   @id @default(cuid())
  memoryId     String   @map("memory_id")
  content      String
  title        String
  importance   Int
  changedAt    DateTime @default(now()) @map("changed_at")
  changeReason String?  @map("change_reason")

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@map("memory_versions")
}

model MemoryAnchor {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  name        String
  description String?
  pattern     String
  patternType String   @default("KEYWORD") @map("pattern_type")
  memoryIds   String[] @default([]) @map("memory_ids")
  isActive    Boolean  @default(true) @map("is_active")
  priority    Int      @default(3)
  hitCount    Int      @default(0) @map("hit_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("memory_anchors")
}

model Notification {
  id          String   @id @default(cuid())
  projectId   String?  @map("project_id")
  type        String
  title       String
  body        String
  memoryId    String?  @map("memory_id")
  isRead      Boolean  @default(false) @map("is_read")
  isDismissed Boolean  @default(false) @map("is_dismissed")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model DayState {
  id        String   @id @default(cuid())
  date      String
  focus     String?
  energy    Int?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([date])
  @@map("day_states")
}

model ChatSession {
  id          String   @id @default(cuid())
  projectSlug String   @default("__free__") @map("project_slug")
  projectName String   @default("Chat Livre") @map("project_name")
  title       String   @default("Nova conversa")
  messages    Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("chat_sessions")
}

model AIConfig {
  id        String   @id @default(cuid())
  role      String   @unique
  provider  String
  model     String
  apiKey    String   @map("api_key")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ai_configs")
}

model BrainDigest {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  type         String   @default("weekly")
  period       String
  summary      String
  insights     Json
  hotTopics    Json     @map("hot_topics")
  coldTopics   Json     @map("cold_topics")
  gaps         Json
  healthScore  Int      @map("health_score")
  memoriesIn   Int      @map("memories_in")
  newSyntheses Int      @default(0) @map("new_syntheses")
  createdAt    DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("brain_digests")
}

model AuditLog {
  id               String   @id @default(cuid())
  projectId        String?  @map("project_id")
  sessionId        String?  @map("session_id")
  tool             String
  input            Json
  outputSummary    String?  @map("output_summary")
  promptTokens     Int?     @map("prompt_tokens")
  completionTokens Int?     @map("completion_tokens")
  estimatedCostUsd Float?   @map("estimated_cost_usd")
  createdAt        DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
