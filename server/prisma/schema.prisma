generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  memories      Memory[]
  connections   ProjectConnection[]
  tasks         Task[]
  auditLogs     AuditLog[]
  writeRequests WriteRequest[]

  @@map("projects")
}

model Memory {
  id          String     @id @default(cuid())
  projectId   String     @map("project_id")
  type        MemoryType
  title       String
  content     String
  tags        String[]
  importance  Int        @default(3)
  isPinned    Boolean    @default(false) @map("is_pinned")
  embedding   Unsupported("vector(1536)")?
  accessCount Int        @default(0) @map("access_count")
  accessedAt  DateTime?  @map("accessed_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  links    MemoryLink[] @relation("LinkFrom")
  linkedBy MemoryLink[] @relation("LinkTo")

  @@map("memories")
}

enum MemoryType {
  DECISION
  CONTEXT
  PATTERN
  NOTE
  BUG_FIX
  ARCHITECTURE
  BRAIN

  @@map("memory_type")
}

model MemoryLink {
  id        String   @id @default(cuid())
  fromId    String   @map("from_id")
  toId      String   @map("to_id")
  relation  LinkType
  weight    Float    @default(1.0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  from Memory @relation("LinkFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   Memory @relation("LinkTo",   fields: [toId],   references: [id], onDelete: Cascade)

  @@unique([fromId, toId, relation])
  @@map("memory_links")
}

enum LinkType {
  EXTENDS
  SUPERSEDES
  CONTRADICTS
  DEPENDS_ON
  EXAMPLE_OF
  RELATED

  @@map("link_type")
}

model ProjectConnection {
  id               String         @id @default(cuid())
  projectId        String         @map("project_id")
  type             ConnectionType
  name             String
  connectionString String         @map("connection_string")
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  writeRequests WriteRequest[]

  @@map("project_connections")
}

enum ConnectionType {
  POSTGRES
  REDIS

  @@map("connection_type")
}

model WriteRequest {
  id            String             @id @default(cuid())
  projectId     String             @map("project_id")
  connectionId  String             @map("connection_id")
  sql           String
  reason        String
  circumstances String
  status        WriteRequestStatus @default(PENDING)
  result        String?
  requestedAt   DateTime           @default(now()) @map("requested_at")
  resolvedAt    DateTime?          @map("resolved_at")

  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  connection ProjectConnection @relation(fields: [connectionId], references: [id])

  @@map("write_requests")
}

enum WriteRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED

  @@map("write_request_status")
}

model Task {
  id          String       @id @default(cuid())
  projectId   String       @map("project_id")
  title       String
  description String?
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(MEDIUM)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED

  @@map("task_status")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("task_priority")
}

model ExternalService {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String   @map("display_name")
  apiUrl        String   @map("api_url")
  adminEmail    String   @map("admin_email")
  adminPassword String   @map("admin_password")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("external_services")
}

model AuditLog {
  id            String   @id @default(cuid())
  projectId     String?  @map("project_id")
  sessionId     String?  @map("session_id")
  tool          String
  input         Json
  outputSummary String?  @map("output_summary")
  createdAt     DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
