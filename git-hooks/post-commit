#!/bin/sh
# git hook: post-commit
# Envia commits fix: automaticamente para o brain do memory-mcp-server.
# Instale copiando para .git/hooks/post-commit e tornando executável.
# Ou rode: sh memory-mcp-server/git-hooks/install.sh

MCP_URL="${MCP_URL:-https://ferramentas-memory-mcp-server.m5mfeg.easypanel.host}"
MCP_KEY="${MCP_KEY:-}"
PROJECT="${MCP_PROJECT:-}"

# Sem chave configurada → sai silenciosamente
if [ -z "$MCP_KEY" ] || [ -z "$PROJECT" ]; then
  exit 0
fi

# Lê a mensagem do último commit
COMMIT_MSG=$(git log -1 --pretty=%s 2>/dev/null)

# Só processa commits fix:
case "$COMMIT_MSG" in
  fix:*|fix\(*\):*|FIX:*)
    ;;
  *)
    exit 0
    ;;
esac

# Diff stat (arquivos alterados) — pode ter quebras de linha reais
DIFF_STAT=$(git diff --stat HEAD~1 HEAD 2>/dev/null | tail -5)
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")
REPO_PATH=$(pwd)

# ⚠️  Constrói o JSON usando node para escapar corretamente:
# - quebras de linha no DIFF_STAT
# - barras invertidas em REPO_PATH (Windows)
# - aspas e caracteres especiais na mensagem do commit
export _MCP_PROJECT="$PROJECT"
export _MCP_MSG="$COMMIT_MSG"
export _MCP_DIFF="$DIFF_STAT"
export _MCP_BRANCH="$BRANCH"
export _MCP_REPO="$REPO_PATH"

PAYLOAD=$(node -e "
const d = {
  project:       process.env._MCP_PROJECT,
  commitMessage: process.env._MCP_MSG,
  diffStat:      process.env._MCP_DIFF,
  branch:        process.env._MCP_BRANCH,
  repoPath:      process.env._MCP_REPO,
};
process.stdout.write(JSON.stringify(d));
" 2>/dev/null)

# Se node não estiver disponível ou falhar, sai silenciosamente
[ -z "$PAYLOAD" ] && exit 0

# Envia para o brain (fire-and-forget — não bloqueia o commit)
curl -s -o /dev/null \
  -X POST \
  -H "Authorization: Bearer ${MCP_KEY}" \
  -H "Content-Type: application/json" \
  -d "$PAYLOAD" \
  "${MCP_URL}/hooks/git-learn" &

exit 0
