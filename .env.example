# ── Banco de dados (container dedicado do MCP) ───────────────────────────────
DATABASE_URL=postgresql://mcp_user:mcp_password@mcp-postgres:5432/mcp_db

# ── Redis (container dedicado do MCP) ────────────────────────────────────────
REDIS_URL=redis://mcp-redis:6379

# ── OpenAI (embeddings) ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Autenticação do MCP Server (Claude Code vai usar essa key) ────────────────
MCP_API_KEY=troque-por-uma-chave-secreta-longa

# ── Login do painel frontend ──────────────────────────────────────────────────
ADMIN_EMAIL=seu@email.com
ADMIN_PASSWORD=sua-senha-segura

# ── JWT (para o painel frontend) ──────────────────────────────────────────────
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio

# ── Chave de criptografia para connection strings (32 bytes = 64 chars hex) ───
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3100
NODE_ENV=production
